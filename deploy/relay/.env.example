# Public URL that phones and local MobileVC nodes import.
# Default public deployment is HTTPS/WSS on port 9443.
# Do not add /relay/client, /relay/agent, or a query string.
RELAY_PUBLIC_URL=wss://relay.example.com:9443

# Domain name served by the bundled Caddy reverse proxy.
RELAY_DOMAIN=relay.example.com

# HTTPS/WSS port published by Caddy.
CADDY_HTTPS_PORT=9443

# DNS-01 provider template. Pick one:
#   ./Caddyfile.cloudflare
#   ./Caddyfile.alidns
#   ./Caddyfile.dnspod
CADDYFILE_PATH=./Caddyfile.cloudflare

# Caddy.DNS.Dockerfile supports Cloudflare and AliDNS on current Caddy.
# DNSPod uses a legacy plugin and must use Caddy.DNSPod.Dockerfile.
CADDY_DOCKERFILE=Caddy.DNS.Dockerfile

# Cloudflare DNS-01 token. Required when CADDYFILE_PATH=./Caddyfile.cloudflare.
# Scope it to the target zone with Zone:Read and DNS:Edit.
CF_API_TOKEN=

# Alibaba Cloud AliDNS DNS-01 credentials.
# Required when CADDYFILE_PATH=./Caddyfile.alidns.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Tencent DNSPod DNS-01 token.
# Required when CADDYFILE_PATH=./Caddyfile.dnspod.
# caddy-dns/dnspod expects APP_ID,APP_TOKEN.
# Also set CADDY_DOCKERFILE=Caddy.DNSPod.Dockerfile.
DNSPOD_TOKEN=

# Optional image/version label embedded into /version.
MOBILEVC_RELAY_VERSION=dev

# If a reverse proxy terminates HTTPS and forwards to relay:9000,
# set this to the proxy container/private CIDR. Do not use 0.0.0.0/0.
RELAY_TRUSTED_PROXY_CIDRS=172.16.0.0/12

# Production security defaults.
RELAY_REQUIRE_E2EE=true
RELAY_PLAINTEXT_TEST_MODE=false

# Runtime limits.
RELAY_MAX_SESSIONS=1000
RELAY_MAX_AGENT_CONNS=1000
RELAY_MAX_CLIENT_CONNS=2000
RELAY_MAX_CONNS_PER_IP=20
RELAY_FORWARD_QUEUE_SIZE=64
RELAY_MAX_PAYLOAD_BYTES=33554432

# Selected-route metadata. The public relay does not expose /download or /ws
# directly; these values are policy metadata enforced after E2EE by the local
# MobileVC relay agent.
RELAY_HTTP_ALLOWLIST=GET:/healthz,GET:/version,GET:/download
RELAY_WS_ALLOWLIST=GET:/ws
